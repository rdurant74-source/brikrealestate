---
import BaseLayout from "../layouts/BaseLayout.astro";
const description = "Rudolph “Realtor Rudy” Durant — licensed Georgia Realtor. Powered by CJ Property Solutions LLC.";
---

<BaseLayout title="About | BRIK Real Estate" description={description}>
  <section style="padding:28px 0 10px">
    <h2 style="font-size:34px;line-height:1.1;margin:0 0 10px;letter-spacing:-.5px">About</h2>
    <p style="margin:0 0 18px;color:var(--muted);max-width:75ch">{description}</p>


   <div style="display:flex;gap:20px;align-items:flex-start;flex-wrap:wrap;margin-top:16px">
  <img
    src="/images/rudy-headshot.JPG"
    alt="Rudolph “Realtor Rudy” Durant"
    width="200"
    height="240"
    style="
      display:block;
      object-fit:cover;
      border-radius:18px;
      border:1px solid var(--line);
      background:#f5f5f5;
    "
  />

  <div style="max-width:720px">
    <p style="margin:0 0 12px;color:var(--text)">
      I’m Rudolph “Realtor Rudy” Durant, a licensed Georgia Realtor serving Atlanta and surrounding communities.
      BRIK was created to make real estate clearer, calmer, and more strategic — whether you’re buying, selling,
      or just trying to understand your options.
    </p>

    <p style="margin:0;color:var(--muted)">
      My approach blends education, market awareness, and practical planning so clients can move with confidence,
      not pressure.
    </p>
  </div>
</div>

  </section>
</BaseLayout>
