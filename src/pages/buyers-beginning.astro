---
import BaseLayout from "../layouts/BaseLayout.astro";
const description = "15 questions that place you on your real estate journey — and tell you exactly what to do next.";
---

<BaseLayout title="Buyers Beginning | BRIK Real Estate" description={description}>
  <section style="padding:28px 0 48px">

    <!-- Header -->
    <div style="margin-bottom:28px">
      <h2 style="font-size:36px;font-weight:900;letter-spacing:-.6px;margin-bottom:10px">Buyers Beginning</h2>
      <p style="max-width:72ch;font-size:15px;line-height:1.75;color:var(--muted)">
        This isn't a personality quiz. It's a diagnostic. 15 questions that assess your mindset, financial readiness, risk tolerance, and property fit — and give you a clear, honest picture of where you stand and what to do next.
      </p>
    </div>

    <!-- Progress Bar -->
    <div class="card" style="margin-bottom:16px">
      <div style="display:flex;gap:12px;align-items:center;justify-content:space-between;flex-wrap:wrap">
        <div>
          <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);margin-bottom:4px">Progress</div>
          <div id="progressText" style="font-weight:800;font-size:18px;color:var(--text)">0 / 15</div>
        </div>
        <div style="flex:1;max-width:400px">
          <div style="height:6px;background:var(--line);border-radius:999px;overflow:hidden">
            <div id="progressBar" style="height:100%;width:0%;background:var(--accent);border-radius:999px;transition:width .3s ease"></div>
          </div>
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap">
          <button id="resetBtn" class="pill" type="button">Reset</button>
          <a class="pill primary" href="/intake">Skip to Intake</a>
        </div>
      </div>
    </div>

    <!-- Quiz Form -->
    <form id="quiz">
      <div style="display:grid;gap:14px">

        <!-- Q1 -->
        <div class="card">
          <fieldset>
            <legend>1 — What is driving your desire to buy real estate right now?</legend>
            <div style="display:grid;gap:8px;margin-top:8px">
              <label><input type="radio" name="q1" value="resident:2 readiness:2" /> I want stability — a place that is mine, in a neighborhood I choose.</label>
              <label><input type="radio" name="q1" value="investor:2 readiness:2" /> I want a deal that makes financial sense on paper.</label>
              <label><input type="radio" name="q1" value="resident:1 investor:1 readiness:1" /> Both — I want to live smart and build wealth at the same time.</label>
              <label><input type="radio" name="q1" value="readiness:0" /> I'm not sure yet. I know I should buy but haven't figured out why.</label>
            </div>
          </fieldset>
        </div>

        <!-- Q2 -->
        <div class="card">
          <fieldset>
            <legend>2 — How would you describe your financial position right now?</legend>
            <div style="display:grid;gap:8px;margin-top:8px">
              <label><input type="radio" name="q2" value="readiness:4" /> Pre-approved, down payment saved, reserves in place.</label>
              <label><input type="radio" name="q2" value="readiness:3" /> Down payment saved, know my budget, haven't talked to a lender yet.</label>
              <label><input type="radio" name="q2" value="readiness:2" /> Actively saving. Credit is okay. Getting closer.</label>
              <label><input type="radio" name="q2" value="readiness:1" /> Saving but still building — credit needs work or income is inconsistent.</label>
              <label><input type="radio" name="q2" value="readiness:0" /> Not there yet. I need to understand what I'm working toward first.</label>
            </div>
          </fieldset>
        </div>

        <!-- Q3 -->
        <div class="card">
          <fieldset>
            <legend>3 — Do you know your credit score range?</legend>
            <div style="display:grid;gap:8px;margin-top:8px">
              <label><input type="radio" name="q3" value="readiness:3" /> Yes — above 700.</label>
              <label><input type="radio" name="q3" value="readiness:2" /> Yes — between 620 and 700.</label>
              <label><input type="radio" name="q3" value="readiness:1" /> Yes — below 620. I'm working on it.</label>
              <label><input type="radio" name="q3" value="readiness:0" /> No — I haven't checked recently.</label>
            </div>
          </fieldset>
        </div>

        <!-- Q4 -->
        <div class="card">
          <fieldset>
            <legend>4 — When would you realistically like to close on a property?</legend>
            <div style="display:grid;gap:8px;margin-top:8px">
              <label><input type="radio" name="q4" value="readiness:4" /> Within the next 3 months.</label>
              <label><input type="radio" name="q4" value="readiness:3" /> 3 to 6 months.</label>
              <label><input type="radio" name="q4" value="readiness:2" /> 6 to 12 months.</label>
              <label><input type="radio" name="q4" value="readiness:1" /> 12 to 24 months.</label>
              <label><input type="radio" name="q4" value="readiness:0" /> No specific timeline — I'm in research mode.</label>
            </div>
          </fieldset>
        </div>

        <!-- Q5 -->
        <div class="card">
          <fieldset>
            <legend>5 — Which statement reflects how you think about property?</legend>
            <div style="display:grid;gap:8px;margin-top:8px">
              <label><input type="radio" name="q5" value="resident:2" /> A home is where I build my life. The financials matter but so does how it feels.</label>
              <label><input type="radio" name="q5" value="investor:2" /> A property is an asset. Emotion is a liability in real estate decisions.</label>
              <label><input type="radio" name="q5" value="resident:1 investor:1" /> Both. I want a home I love that also makes financial sense.</label>
              <label><input type="radio" name="q5" value="readiness:1" /> I'm still forming my philosophy. I need a framework before I can answer this.</label>
            </div>
          </fieldset>
        </div>

        <!-- Q6 -->
        <div class="card">
          <fieldset>
            <legend>6 — How do you feel about property maintenance and repairs?</legend>
            <div style="display:grid;gap:8px;margin-top:8px">
              <label><input type="radio" name="q6" value="sfh:2" /> I'm fine handling repairs if it means I own the structure and land outright.</label>
              <label><input type="radio" name="q6" value="condo:2" /> I'd rather pay HOA fees than deal with maintenance myself.</label>
              <label><input type="radio" name="q6" value="condo:1 sfh:1" /> I can do either — it depends on the deal and the numbers.</label>
              <label><input type="radio" name="q6" value="readiness:0" /> I'm not sure what I'm actually signing up for yet.</label>
            </div>
          </fieldset>
        </div>

        <!-- Q7 -->
        <div class="card">
          <fieldset>
            <legend>7 — What matters most in your first purchase?</legend>
            <div style="display:grid;gap:8px;margin-top:8px">
              <label><input type="radio" name="q7" value="sfh:2" /> Space, privacy, a yard — room to grow and make it mine.</label>
              <label><input type="radio" name="q7" value="condo:2" /> Low maintenance, good location, lock-and-leave lifestyle.</label>
              <label><input type="radio" name="q7" value="investor:2" /> The ability to rent it out, house hack, or hold it as an investment.</label>
              <label><input type="radio" name="q7" value="resident:2" /> A stable, comfortable home base I'm proud to come home to.</label>
            </div>
          </fieldset>
        </div>

        <!-- Q8 -->
        <div class="card">
          <fieldset>
            <legend>8 — Are you open to buying a property that needs work?</legend>
            <div style="display:grid;gap:8px;margin-top:8px">
              <label><input type="radio" name="q8" value="investor:3" /> Yes — I actively look for value-add opportunities. I know how to evaluate them.</label>
              <label><input type="radio" name="q8" value="investor:2" /> Maybe — if the numbers clearly worked and the scope was manageable.</label>
              <label><input type="radio" name="q8" value="resident:1" /> Probably not — I want move-in ready. I don't want a project.</label>
              <label><input type="radio" name="q8" value="resident:0 condo:1" /> No. I want something turnkey with minimal surprises.</label>
            </div>
          </fieldset>
        </div>

        <!-- Q9 -->
        <div class="card">
          <fieldset>
            <legend>9 — How long do you plan to own your first property?</legend>
            <div style="display:grid;gap:8px;margin-top:8px">
              <label><input type="radio" name="q9" value="resident:2 investor:1" /> 10+ years. This is a long-term commitment.</label>
              <label><input type="radio" name="q9" value="resident:1 investor:1" /> 5 to 10 years. I'll stay a while but life could change.</label>
              <label><input type="radio" name="q9" value="investor:2" /> 2 to 5 years. I plan to move or upgrade and keep this one as a rental.</label>
              <label><input type="radio" name="q9" value="investor:3" /> Less than 2 years. I want to flip or house hack and redeploy capital.</label>
            </div>
          </fieldset>
        </div>

        <!-- Q10 -->
        <div class="card">
          <fieldset>
            <legend>10 — Are you familiar with terms like cap rate, NOI, and cash-on-cash return?</legend>
            <div style="display:grid;gap:8px;margin-top:8px">
              <label><input type="radio" name="q10" value="investor:3" /> Yes — I use these regularly when evaluating properties.</label>
              <label><input type="radio" name="q10" value="investor:2" /> I know what they mean but haven't used them in a real deal yet.</label>
              <label><input type="radio" name="q10" value="investor:1" /> I've heard the terms but don't really understand them yet.</label>
              <label><input type="radio" name="q10" value="readiness:1" /> No — this is new territory for me.</label>
            </div>
          </fieldset>
        </div>

        <!-- Q11 -->
        <div class="card">
          <fieldset>
            <legend>11 — Would you consider buying a multi-unit property (duplex, triplex) and renting out units?</legend>
            <div style="display:grid;gap:8px;margin-top:8px">
              <label><input type="radio" name="q11" value="investor:3" /> Yes — that's actually my strategy. House hacking makes a lot of sense.</label>
              <label><input type="radio" name="q11" value="investor:2" /> I'm open to it if the numbers work and I can manage tenants.</label>
              <label><input type="radio" name="q11" value="resident:1" /> Probably not — I want a home, not a landlord situation.</label>
              <label><input type="radio" name="q11" value="resident:2" /> No. I want my own space without shared walls or tenants.</label>
            </div>
          </fieldset>
        </div>

        <!-- Q12 -->
        <div class="card">
          <fieldset>
            <legend>12 — If the market dropped 10% after you bought, how would you feel?</legend>
            <div style="display:grid;gap:8px;margin-top:8px">
              <label><input type="radio" name="q12" value="investor:2 resident:1" /> Fine. I'm buying for the long term. Short-term fluctuations don't change my plan.</label>
              <label><input type="radio" name="q12" value="resident:2" /> Uncomfortable, but I could handle it. I'd focus on staying put.</label>
              <label><input type="radio" name="q12" value="readiness:1" /> Very stressed. I'd worry about being underwater.</label>
              <label><input type="radio" name="q12" value="readiness:0" /> That scenario terrifies me. I need to understand risk better before buying.</label>
            </div>
          </fieldset>
        </div>

        <!-- Q13 -->
        <div class="card">
          <fieldset>
            <legend>13 — Have you identified the area or market where you want to buy?</legend>
            <div style="display:grid;gap:8px;margin-top:8px">
              <label><input type="radio" name="q13" value="readiness:3" /> Yes — specific neighborhood or zip code. I've been tracking it.</label>
              <label><input type="radio" name="q13" value="readiness:2" /> I have a general area in mind but haven't narrowed it down.</label>
              <label><input type="radio" name="q13" value="readiness:1" /> I know the region but the specific market is still wide open.</label>
              <label><input type="radio" name="q13" value="readiness:0" /> Not yet — I'm still figuring out where I even want to be.</label>
            </div>
          </fieldset>
        </div>

        <!-- Q14 -->
        <div class="card">
          <fieldset>
            <legend>14 — Which of these best describes your current housing situation?</legend>
            <div style="display:grid;gap:8px;margin-top:8px">
              <label><input type="radio" name="q14" value="readiness:3" /> Renting and ready — I've been planning this move and I'm motivated.</label>
              <label><input type="radio" name="q14" value="resident:1 readiness:2" /> Renting and comfortable — buying would be an upgrade but I'm not urgent.</label>
              <label><input type="radio" name="q14" value="investor:1 readiness:2" /> Own my home — I'm looking for an investment or additional property.</label>
              <label><input type="radio" name="q14" value="readiness:1" /> Living with family — saving aggressively and getting ready to move.</label>
            </div>
          </fieldset>
        </div>

        <!-- Q15 -->
        <div class="card">
          <fieldset>
            <legend>15 — What does success look like for you 5 years after buying?</legend>
            <div style="display:grid;gap:8px;margin-top:8px">
              <label><input type="radio" name="q15" value="resident:3" /> I'm settled in a home I love in the right neighborhood. Equity is a bonus.</label>
              <label><input type="radio" name="q15" value="investor:2 resident:1" /> I own my home and it's also generating income or appreciated significantly.</label>
              <label><input type="radio" name="q15" value="investor:3" /> I've leveraged my first purchase into a second property. The portfolio is growing.</label>
              <label><input type="radio" name="q15" value="readiness:1" /> I just want to not regret the decision. I need to make a smart move.</label>
            </div>
          </fieldset>
        </div>

        <!-- Submit Row -->
        <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;margin-top:8px">
          <button id="scoreBtn" class="pill primary" type="button">Get my results →</button>
          <a class="pill" href="/glossary">Build vocabulary first</a>
          <a class="pill" href="/case-studies">Read case studies</a>
          <span id="validation" style="color:var(--muted);font-size:12px"></span>
        </div>

      </div>
    </form>

    <!-- Results -->
    <div id="results" style="display:none;margin-top:16px"></div>

  </section>

  <script is:inline>
    const TOTAL = 15;
    const quiz = document.getElementById("quiz");
    const scoreBtn = document.getElementById("scoreBtn");
    const resetBtn = document.getElementById("resetBtn");
    const results = document.getElementById("results");
    const validation = document.getElementById("validation");
    const progressText = document.getElementById("progressText");
    const progressBar = document.getElementById("progressBar");

    function parseValue(val) {
      const out = {};
      val.trim().split(/\s+/).forEach(function(pair) {
        const parts = pair.split(":");
        if (parts.length === 2) out[parts[0]] = (out[parts[0]] || 0) + parseInt(parts[1], 10);
      });
      return out;
    }

    function getProgress() {
      let answered = 0;
      for (let i = 1; i <= TOTAL; i++) {
        if (quiz.querySelector('input[name="q' + i + '"]:checked')) answered++;
      }
      progressText.textContent = answered + " / " + TOTAL;
      progressBar.style.width = Math.round((answered / TOTAL) * 100) + "%";
      return answered;
    }

    function collectScores() {
      const scores = { resident: 0, investor: 0, condo: 0, sfh: 0, readiness: 0 };
      for (let i = 1; i <= TOTAL; i++) {
        const sel = quiz.querySelector('input[name="q' + i + '"]:checked');
        if (!sel) return null;
        const parsed = parseValue(sel.value);
        for (const k in parsed) scores[k] = (scores[k] || 0) + parsed[k];
      }
      return scores;
    }

    function readinessLabel(r) {
      if (r >= 22) return {
        label: "Ready to Move",
        badge: "🟢",
        desc: "Your financial position and timeline are aligned. The next step is finding the right property and submitting intake so we can build your plan.",
        next: "Submit Intake"
      };
      if (r >= 15) return {
        label: "Close — Activate Now",
        badge: "🟡",
        desc: "You're in range. A structured pre-approval conversation and market orientation will get you to offer-ready within 60–90 days.",
        next: "Submit Intake"
      };
      if (r >= 8) return {
        label: "Building Phase",
        badge: "🟠",
        desc: "You're on the path but need 3–12 months of focused preparation — credit, savings, or market clarity. Use this time strategically.",
        next: "Start with Education"
      };
      return {
        label: "Foundation First",
        badge: "🔴",
        desc: "Start with the fundamentals. The Glossary, case studies, and a credit/savings plan will get you ready. Rushing this stage is expensive.",
        next: "Go to Education"
      };
    }

    function mindsetLabel(resident, investor) {
      if (investor - resident >= 4) return {
        label: "Investor-Minded",
        desc: "You think in numbers, risk, and upside. Your first purchase should be evaluated like a deal — because for you, it is."
      };
      if (investor - resident >= 2) return {
        label: "Investor-Leaning",
        desc: "You have one foot in each world. Strategy matters to you, but so does living well. House hacking or a rentable SFR might be your sweet spot."
      };
      if (resident - investor >= 4) return {
        label: "Resident-Minded",
        desc: "Lifestyle, stability, and community drive your decision. That's legitimate. A home you love in the right area compounds in value too."
      };
      if (resident - investor >= 2) return {
        label: "Resident-Leaning",
        desc: "You want a home first — but you're not ignoring the financial side. A good buyer's agent will help you find something that does both."
      };
      return {
        label: "Balanced Thinker",
        desc: "You want lifestyle and strategy aligned. That's the ideal — and it's achievable with the right framework and the right property."
      };
    }

    function propertyLabel(condo, sfh, investor) {
      if (investor >= 6) return {
        label: "Multi-Family / House Hack",
        desc: "Your profile points toward a duplex or small multi-family. Live in one unit, rent the others. Residential financing, investment returns."
      };
      if (sfh - condo >= 3) return {
        label: "Single-Family Home",
        desc: "You want space, control, and structure you own outright. Budget for maintenance — it's real — but so is the equity."
      };
      if (condo - sfh >= 3) return {
        label: "Condo or Townhome",
        desc: "Low maintenance and location matter to you. Read the HOA financials carefully — a well-run building is an asset, a poorly run one is a liability."
      };
      return {
        label: "Depends on the Deal",
        desc: "Your preferences don't strongly favor one type. That's fine — let the market, your budget, and the specific opportunity guide you."
      };
    }

    function getCaseStudyLinks(scores) {
      const links = [];

      if (scores.readiness <= 7) {
        links.push({ text: "Credit score not ready: build now vs buy later", href: "/case-studies/credit-not-ready-build-now-vs-buy-later" });
        links.push({ text: "No savings, want to buy: where to actually start", href: "/case-studies/no-savings-want-to-buy" });
        links.push({ text: "First-time homebuyer programs: what's available", href: "/case-studies/first-time-homebuyer-programs" });
      }

      if (scores.investor >= scores.resident && scores.investor >= 6) {
        links.push({ text: "House hacking a duplex: real numbers walkthrough", href: "/case-studies/house-hacking-duplex-real-numbers" });
        links.push({ text: "Long-term rental analysis: does this property cash flow?", href: "/case-studies/long-term-rental-analysis" });
      }

      if (scores.condo > scores.sfh) {
        links.push({ text: "Condo HOA tradeoff vs SFH repairs", href: "/case-studies/condo-hoa-tradeoff-vs-sfh-repairs" });
        links.push({ text: "Special assessments: how to protect yourself", href: "/case-studies/special-assessments-protection" });
      } else if (scores.sfh > scores.condo) {
        links.push({ text: "First-year ownership costs: repairs, reserves, reality", href: "/case-studies/first-year-ownership-costs" });
        links.push({ text: "Single-family vs duplex for a first purchase", href: "/case-studies/single-family-vs-duplex-first-purchase" });
      }

      if (scores.readiness >= 15) {
        links.push({ text: "Offer strategy: clean terms vs escalation clause", href: "/case-studies/offer-strategy-clean-terms-vs-escalation" });
        links.push({ text: "Negotiating after inspection: credits vs repairs", href: "/case-studies/inspection-negotiation-credits-vs-repairs" });
      }

      links.push({ text: "Waiting for the market vs buying now", href: "/case-studies/waiting-for-market-vs-buying-now" });
      links.push({ text: "Choosing your realtor: alignment and what to look for", href: "/case-studies/choosing-your-realtor" });

      // Deduplicate and limit
      const seen = new Set();
      return links.filter(function(l) {
        if (seen.has(l.href)) return false;
        seen.add(l.href);
        return true;
      }).slice(0, 6);
    }

    function renderResults(scores) {
      const mind = mindsetLabel(scores.resident, scores.investor);
      const prop = propertyLabel(scores.condo, scores.sfh, scores.investor);
      const ready = readinessLabel(scores.readiness);
      const caseLinks = getCaseStudyLinks(scores);

      const nextHref = scores.readiness >= 15 ? "/intake" : "/education";
      const nextLabel = scores.readiness >= 15 ? "Submit Intake — build my plan" : "Go to Education Hub";

      results.style.display = "block";
      results.innerHTML = `
        <div class="card" style="border-color:var(--accent-border);background:var(--accent-bg);margin-bottom:14px">
          <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);margin-bottom:8px">Your Results</div>
          <h3 style="margin:0 0 6px;font-size:22px">${ready.badge} ${ready.label}</h3>
          <p style="margin:0;font-size:14px;line-height:1.7;color:var(--muted)">${ready.desc}</p>
        </div>

        <div style="display:grid;gap:14px;grid-template-columns:repeat(12,1fr);margin-bottom:14px">
          <div class="card" style="grid-column:span 6">
            <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);margin-bottom:8px">Your Mindset</div>
            <div style="font-weight:800;font-size:16px;margin-bottom:6px;color:var(--text)">${mind.label}</div>
            <p style="margin:0;font-size:13px;line-height:1.7;color:var(--muted)">${mind.desc}</p>
          </div>
          <div class="card" style="grid-column:span 6">
            <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);margin-bottom:8px">Best Property Fit</div>
            <div style="font-weight:800;font-size:16px;margin-bottom:6px;color:var(--text)">${prop.label}</div>
            <p style="margin:0;font-size:13px;line-height:1.7;color:var(--muted)">${prop.desc}</p>
          </div>
        </div>

        <div class="card" style="margin-bottom:14px">
          <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);margin-bottom:12px">Case Studies Matched to Your Profile</div>
          <div style="display:grid;gap:8px">
            ${caseLinks.map(function(l) {
              return '<a href="' + l.href + '" style="display:flex;align-items:center;gap:10px;padding:10px 14px;border-radius:12px;border:1px solid var(--line);background:var(--bg-card-alt);color:var(--text);font-size:13px;font-weight:500;transition:border-color .15s,background .15s" onmouseover="this.style.borderColor=\'var(--accent-border)\';this.style.background=\'var(--accent-bg)\'" onmouseout="this.style.borderColor=\'var(--line)\';this.style.background=\'var(--bg-card-alt)\'">'
                + '<span style="color:var(--accent);font-size:16px">→</span>'
                + l.text
                + '</a>';
            }).join("")}
          </div>
        </div>

        <div class="card" style="background:var(--bg-card-alt)">
          <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);margin-bottom:8px">Your Next Step</div>
          <p style="margin:0 0 14px;font-size:14px;line-height:1.7;color:var(--muted)">
            ${scores.readiness >= 15
              ? "You have the foundation to move forward. Submit intake and we'll map your specific situation — budget, timeline, property type, and market — into a real action plan."
              : "Use the education resources to build your foundation before committing capital. The buyers who close confidently are the ones who prepared intentionally."}
          </p>
          <div style="display:flex;gap:10px;flex-wrap:wrap">
            <a class="pill primary" href="${nextHref}">${nextLabel}</a>
            <a class="pill" href="/glossary">Explore the Glossary</a>
            <a class="pill" href="/market-intel">GA Intel</a>
          </div>
        </div>

        <div style="margin-top:12px;font-size:12px;color:var(--muted-light);line-height:1.6">
          Results are based on your answers and are directional — not a guarantee. When you submit intake, your actual numbers (income, credit, savings, timeline) will shape the full picture.
        </div>
      `;

      if (window.innerWidth < 900) {
        results.querySelectorAll('[style*="grid-column:span 6"]').forEach(function(el) {
          el.style.gridColumn = "span 12";
        });
      }

      results.scrollIntoView({ behavior: "smooth", block: "start" });
    }

    quiz.addEventListener("change", function() {
      getProgress();
      var answered = getProgress();
      validation.textContent = answered === TOTAL ? "All answered — get your results." : "";
    });

    scoreBtn.addEventListener("click", function() {
      var answered = getProgress();
      if (answered !== TOTAL) {
        validation.textContent = "Answer all " + TOTAL + " questions to see results (" + answered + "/" + TOTAL + " done).";
        return;
      }
      validation.textContent = "";
      var scores = collectScores();
      if (scores) renderResults(scores);
    });

    resetBtn.addEventListener("click", function() {
      quiz.reset();
      results.style.display = "none";
      validation.textContent = "";
      getProgress();
    });

    getProgress();
  </script>
</BaseLayout>
